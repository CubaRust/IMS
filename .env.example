APP_NAME=EQYCC_CUBA_IMS
APP_ENV=dev
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/eqycc_cuba_ims
DATABASE_MAX_CONNECTIONS=10

RUST_LOG=info,cuba=debug
RUST_BACKTRACE=1

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_TTL_SECONDS=86400

# Migration 策略(docs/database/migration-rule.md)
# dev/test: auto  prod: manual
MIGRATION_MODE=auto
